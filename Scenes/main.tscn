[sub_resource type="GDScript" id="GDScript_8gbba"]
script/source = "extends CharacterBody2D

@export var bullet: PackedScene
@export var max_shot: int
@onready var shoot_point: Marker2D = %Marker2D
@onready var cooldown: Timer = $Cooldown
@onready var enemy_sight: RayCast2D = $RayCast2D
@onready var destroyed: AnimationPlayer = $AnimationPlayer
@onready var despawn_timer: Timer = $Despawn_timer
@onready var enemy_cover: AnimationPlayer = $AnimationPlayer
var active: bool = true
signal victory

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	move_and_slide()
	if $RayCast2D.is_colliding() and max_shot == 0:
		cooldown.start()
		print(\"Detected\")
		var bulletInstance = bullet.instantiate()
		get_parent().add_child(bulletInstance)
		bulletInstance.global_position = shoot_point.global_position
		max_shot += 1
	else:
		pass
	

func _on_hitbox_area_entered(_area: Area2D) -> void:
	die()
	pass # Replace with function body.

func die():
	active = false
	var death_sound = preload(\"res://Scenes/death_sound.tscn\").instantiate()
	death_sound.global_position = global_position
	get_tree().current_scene.add_child(death_sound)
	death_sound.play()
	if active == false:
		Autoload.enemy_death_count += 1
		print(\"COUNT: \" + str(Autoload.enemy_death_count))
		enemy_sight.enabled = false
		cooldown.paused = true
		destroyed.play(\"exploding\")
		despawn_timer.start()

func _on_cooldown_timeout() -> void:
	print(\"Timer Up\")
	max_shot = 0
	pass # Replace with function body.

func _on_friendly_cone_body_entered(body: CharacterBody2D) -> void:
	enemy_sight.enabled = false
	print(\"Friendly\")
	pass # Replace with function body.

func _on_friendly_cone_body_exited(body: CharacterBody2D) -> void:
	enemy_sight.enabled = true
	print(\"Target Locked\")
	pass # Replace with function body.

func _on_friendly_cone_2_body_entered(body: CharacterBody2D) -> void:
	enemy_sight.enabled = false
	print(\"Friendly\")
	pass # Replace with function body.


func _on_friendly_cone_2_body_exited(body: CharacterBody2D) -> void:
	enemy_sight.enabled = true
	print(\"Target Locked\")
	pass # Replace with function body.


func _on_friendly_cone_3_body_entered(body: CharacterBody2D) -> void:
	enemy_sight.enabled = false
	print(\"Friendly\")
	pass # Replace with function body.


func _on_friendly_cone_3_body_exited(body: CharacterBody2D) -> void:
	enemy_sight.enabled = true
	print(\"Target Locked\")
	pass # Replace with function body.


func _on_friendly_cone_4_body_entered(body: CharacterBody2D) -> void:
	enemy_sight.enabled = false
	print(\"Friendly\")
	pass # Replace with function body.


func _on_friendly_cone_4_body_exited(body: CharacterBody2D) -> void:
	enemy_sight.enabled = true
	print(\"Target Locked\")
	pass # Replace with function body.


func _on_enraged_1_area_entered(area: Area2D) -> void:
	print(\"RAGEEEEEE\")
	pass # Replace with function body.

func _on_despawn_timer_timeout() -> void:
	queue_free()
	pass # Replace with function body.
"

